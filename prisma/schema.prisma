generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
}

enum FieldType {
  TEXT
  NUMBER
  SELECT
  MULTISELECT
  BOOLEAN
  FILE
  BRAND_REF
  KEY_VALUE
  RANGE
}

enum FilterWidget {
  CHECKBOX
  RANGE
  SWITCH
  SEARCHABLE_LIST
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  imageUrl        String?
  parentId        String?
  parent          Category?       @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[]      @relation("CategoryTree")
  sortOrder       Int             @default(0)
  h1              String?
  metaTitle       String?
  metaDescription String?
  templateId      String?
  template        FieldTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  products        Product[]
  filterGroups    FilterGroup[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Brand {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logoUrl         String?
  description     String?
  metaTitle       String?
  metaDescription String?
  products        Product[]
  fieldValues     ProductFieldValue[] @relation("BrandFieldValues")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FieldTemplate {
  id          String            @id @default(cuid())
  name        String
  description String?
  categories  Category[]
  fields      FieldDefinition[]
  products    Product[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model FilterGroup {
  id         String            @id @default(cuid())
  name       String
  sortOrder  Int               @default(0)
  collapsed  Boolean           @default(false)
  categoryId String?
  category   Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fields     FieldDefinition[]
}

model FieldDefinition {
  id             String              @id @default(cuid())
  templateId     String
  template       FieldTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  groupId        String?
  group          FilterGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  name           String
  slug           String
  type           FieldType
  unit           String?
  required       Boolean             @default(false)
  isFilterable   Boolean             @default(false)
  filterWidget   FilterWidget?
  sortOrder      Int                 @default(0)
  topValuesLimit Int                 @default(8)
  options        FieldOption[]
  values         ProductFieldValue[]

  @@unique([templateId, slug])
  @@index([isFilterable])
}

model FieldOption {
  id         String           @id @default(cuid())
  fieldId    String
  field      FieldDefinition  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  label      String
  slug       String
  sortOrder  Int              @default(0)
  values     ProductFieldValue[]

  @@unique([fieldId, slug])
}

model Product {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  sku              String              @unique
  price            Decimal             @db.Decimal(12, 2)
  oldPrice         Decimal?            @db.Decimal(12, 2)
  inStock          Boolean             @default(true)
  shortDescription String
  fullDescription  String
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId          String?
  brand            Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  templateId       String?
  template         FieldTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  h1               String?
  metaTitle        String?
  metaDescription  String?
  images           ProductImage[]
  documents        ProductDocument[]
  fieldValues      ProductFieldValue[]
  relatedFrom      ProductRelation[]   @relation("RelatedFrom")
  relatedTo        ProductRelation[]   @relation("RelatedTo")
  orderItems       OrderItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([name])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
}

model ProductDocument {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  url       String
  fileName  String?
  sortOrder Int     @default(0)
}

model ProductFieldValue {
  id              String           @id @default(cuid())
  productId       String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  fieldId         String
  field           FieldDefinition  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  valueText       String?
  valueNumber     Decimal?         @db.Decimal(12, 3)
  valueBoolean    Boolean?
  valueFileUrl    String?
  valueJson       Json?
  optionId        String?
  option          FieldOption?     @relation(fields: [optionId], references: [id], onDelete: SetNull)
  brandRefId      String?
  brandRef        Brand?           @relation("BrandFieldValues", fields: [brandRefId], references: [id], onDelete: SetNull)

  @@unique([productId, fieldId, optionId])
  @@index([fieldId, valueNumber])
  @@index([fieldId, optionId])
}

model ProductRelation {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedId String
  related   Product @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)

  @@unique([productId, relatedId])
}

model Order {
  id        String      @id @default(cuid())
  number    Int         @unique @default(autoincrement())
  status    OrderStatus @default(NEW)
  name      String
  phone     String
  email     String?
  comment   String?
  total     Decimal     @db.Decimal(12, 2)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String
  sku       String
  price     Decimal @db.Decimal(12, 2)
  quantity  Int
}

model HomeBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  href        String?
  buttonLabel String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
}

model ContentPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?
  body            String   @default("")
  metaTitle       String?
  metaDescription String?
  h1              String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContact {
  id           String   @id @default("default")
  phone        String?
  email        String?
  telegram     String?
  whatsapp     String?
  maxMessenger String?
  updatedAt    DateTime @updatedAt
}

model SeoTemplate {
  id              String   @id @default(cuid())
  entityType      String
  metaTitle       String
  metaDescription String
  h1              String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Redirect {
  id       String @id @default(cuid())
  fromPath String @unique
  toPath   String
  code     Int    @default(301)
}
