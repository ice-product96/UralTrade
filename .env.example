# --- PostgreSQL (dedicated container, internal Docker network) ---
POSTGRES_USER=uraltrade
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=uraltrade

# Local dev / manual runs. In docker-compose.prod.yml DATABASE_URL is built from POSTGRES_* automatically.
# Use only letters and numbers in POSTGRES_PASSWORD (no @ : / #) to avoid URL parsing issues.
DATABASE_URL=postgresql://uraltrade:change-me-strong-password@postgres:5432/uraltrade?schema=public

# --- App (public URLs, must match your domain) ---
NEXTAUTH_URL=https://uraltrade.ice-product.ru
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
SITE_URL=https://uraltrade.ice-product.ru

# Local port for nginx upstream (not exposed publicly)
APP_PORT=3010

# --- Admin seed (used by npm run db:seed) ---
ADMIN_EMAIL=admin@uraltrade.local
ADMIN_PASSWORD=change-me-admin-password

# --- Order notifications (optional) ---
ORDER_EMAIL_TO=manager@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=UralTrade <no-reply@example.com>
